# Option A — Supabase (rooms, chat, presence, signaling): set both. Run without Node server.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Option B — Node server (Socket.io). Dev: leave empty (Vite proxy to localhost:3001).
# Production / separate deploy: set to backend URL, e.g. https://api.kinofan.example.com (no trailing slash).
# Production build does NOT use proxy; all /api and Socket.io requests go to VITE_API_URL.
VITE_API_URL=

# Optional TURN server (strongly recommended for reliable peer-to-peer connections behind restrictive NATs)
# Example: VITE_TURN_URL=turn:turn.example.com:3478
# If your TURN server requires credentials also set:
# VITE_TURN_USERNAME=someuser
# VITE_TURN_CREDENTIAL=somesecret
# Many hosted providers offer temporary TURN credentials for testing.
